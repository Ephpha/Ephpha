{
  "manifest_version": 3,
  "name": "Ephpha.ai — AI Email Tools",
  "version": "1.0.0",
  "description": "Write better emails, improve drafts, analyze subject lines, and find the perfect send time — right inside your browser.",
  "permissions": [
    "sidePanel",
    "activeTab"
  ],
  "action": {
    "default_title": "Open Ephpha",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
